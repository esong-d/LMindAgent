.page {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
  border-radius: 16px;
  border: 1px solid var(--border);
  background: #fff;
  box-shadow: var(--shadow);
  overflow: hidden;
}

.body {
  flex: 1;
  min-height: 0;
  display: flex;
  gap: 0;
}

.convPanel {
  flex: 0 1 clamp(240px, 28vw, 320px);
  width: auto;
  min-width: 220px;
  max-width: 360px;
  border-right: 1px solid var(--border);
  background: #fbfbfd;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.convHeader {
  padding: 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  border-bottom: 1px solid var(--border);
  background: #fff;
}

.convTitle {
  font-weight: 800;
  color: var(--text-h);
  letter-spacing: -0.2px;
}

.convActions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.convList {
  flex: 1;
  min-height: 0;
  overflow: auto;
  padding: 10px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.convRow {
  display: flex;
  align-items: flex-start;
  gap: 0;
  position: relative;
}

.convItem {
  flex: 1;
  min-width: 0;
  position: relative;
  border: 1px solid rgba(2, 6, 23, 0.08);
  background: rgba(255, 255, 255, 0.92);
  border-radius: 14px;
  padding: 10px 40px 10px 12px;
  cursor: pointer;
  text-align: left;
  color: var(--text-h);
  transition:
    background 160ms ease,
    border-color 160ms ease,
    box-shadow 160ms ease,
    transform 160ms ease;
  outline: none;
}

.convItem::before {
  content: '';
  position: absolute;
  left: 0;
  top: 10px;
  bottom: 10px;
  width: 3px;
  border-radius: 999px;
  background: transparent;
}

.convItem:hover {
  border-color: rgba(47, 107, 255, 0.22);
  background: #fff;
  box-shadow:
    rgba(2, 6, 23, 0.06) 0 10px 22px -18px,
    rgba(2, 6, 23, 0.05) 0 1px 0;
  transform: translateY(-1px);
}

.convItemActive {
  border-color: rgba(47, 107, 255, 0.42);
  background: linear-gradient(180deg, rgba(238, 242, 255, 0.92) 0%, rgba(255, 255, 255, 0.96) 100%);
  box-shadow: 0 0 0 3px rgba(47, 107, 255, 0.12);
  transform: none;
}

.convItemActive::before {
  background: #2f6bff;
}

.convItem:focus-visible {
  border-color: rgba(47, 107, 255, 0.6);
  box-shadow: 0 0 0 3px rgba(47, 107, 255, 0.18);
}

.convItemTop {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10px;
}

.convItemTitle {
  font-weight: 750;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-clamp: 2;
}

.convItemTime {
  flex: 0 0 auto;
  font-size: 12px;
  color: rgba(15, 23, 42, 0.58);
  white-space: nowrap;
  line-height: 1.2;
  margin-top: 2px;
}

.convItemBottom {
  margin-top: 6px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.convItemTag {
  display: inline-flex;
  align-items: center;
  height: 20px;
  padding: 0 8px;
  border-radius: 999px;
  border: 1px solid rgba(2, 6, 23, 0.08);
  background: rgba(2, 6, 23, 0.03);
  color: rgba(15, 23, 42, 0.72);
  font-size: 12px;
  font-weight: 650;
  max-width: 180px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.convItemLoading {
  font-size: 12px;
  color: rgba(15, 23, 42, 0.58);
  white-space: nowrap;
}

.convDelete {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 28px;
  height: 28px;
  border-radius: 10px;
  border: 1px solid transparent;
  background: transparent;
  color: rgba(15, 23, 42, 0.62);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition:
    opacity 140ms ease,
    background 140ms ease,
    border-color 140ms ease,
    color 140ms ease;
}

.convRow:hover .convDelete,
.convRow:focus-within .convDelete {
  opacity: 1;
  pointer-events: auto;
}

.convDelete:hover {
  background: rgba(185, 28, 28, 0.08);
  border-color: rgba(185, 28, 28, 0.18);
  color: #b91c1c;
}

.convDelete:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

.convDeleteIcon {
  width: 16px;
  height: 16px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
}

.convEmpty {
  padding: 18px 10px;
  color: var(--text);
  text-align: center;
}

.thread {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  min-height: 0;
  overflow: hidden;
  background: #fff;
}

.header {
  padding: 14px 18px 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  background: #fff;
  border-bottom: 1px solid var(--border);
}

.title {
  margin: 0;
  color: var(--text-h);
  font-size: 22px;
  font-weight: 750;
  letter-spacing: -0.2px;
}

.subTitle {
  margin-top: 6px;
  color: var(--text);
  font-size: 12px;
}

.headerActions {
  display: flex;
  align-items: center;
  gap: 10px;
}

.messages {
  flex: 1;
  min-height: 0;
  overflow: auto;
  padding: 12px 18px 16px;
  background:
    radial-gradient(1100px 600px at 20% 0%, rgba(47, 107, 255, 0.09) 0%, rgba(47, 107, 255, 0) 55%),
    radial-gradient(900px 520px at 90% 20%, rgba(99, 102, 241, 0.08) 0%, rgba(99, 102, 241, 0) 52%),
    linear-gradient(180deg, #f7f8fa 0%, #f3f5f9 100%);
}

.list {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.row {
  display: flex;
  width: 100%;
}

.rowAssistant {
  justify-content: flex-start;
}

.rowUser {
  justify-content: flex-end;
}

.rowGrouped {
  margin-top: -8px;
}

.rowInner {
  display: flex;
  align-items: flex-end;
  gap: 10px;
  max-width: min(880px, 100%);
  width: 100%;
}

.rowAssistant .rowInner {
  justify-content: flex-start;
}

.rowUser .rowInner {
  justify-content: flex-end;
}

.avatar {
  width: 30px;
  height: 30px;
  border-radius: 10px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: -0.2px;
  flex: 0 0 auto;
  box-shadow: rgba(2, 6, 23, 0.08) 0 1px 1px;
  border: 1px solid rgba(2, 6, 23, 0.08);
}

.avatarAssistant {
  background: rgba(47, 107, 255, 0.12);
  color: #2f6bff;
}

.avatarUser {
  background: linear-gradient(180deg, rgba(47, 107, 255, 0.95) 0%, rgba(35, 89, 255, 0.95) 100%);
  color: #fff;
  border-color: rgba(47, 107, 255, 0.55);
}

.bubbleWrap {
  position: relative;
  max-width: min(760px, 78%);
  min-width: 56px;
}

.bubble {
  width: 100%;
  border-radius: 18px;
  padding: 12px 14px;
  border: 1px solid rgba(2, 6, 23, 0.08);
  box-shadow:
    rgba(2, 6, 23, 0.06) 0 10px 22px -18px,
    rgba(2, 6, 23, 0.05) 0 1px 0;
  background: rgba(255, 255, 255, 0.95);
  text-align: left;
}

.bubbleAssistant {
  background: rgba(255, 255, 255, 0.92);
  color: var(--text-h);
}

.bubbleUser {
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(49, 107, 255, 0.98) 0%, rgba(36, 85, 255, 0.98) 100%);
  border-color: rgba(47, 107, 255, 0.6);
  color: #fff;
  box-shadow:
    rgba(47, 107, 255, 0.22) 0 18px 36px -26px,
    rgba(2, 6, 23, 0.06) 0 10px 22px -18px,
    rgba(2, 6, 23, 0.05) 0 1px 0;
}

.bubbleUser::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(520px 220px at 18% 0%, rgba(255, 255, 255, 0.28) 0%, rgba(255, 255, 255, 0) 56%),
    radial-gradient(420px 220px at 90% 30%, rgba(255, 255, 255, 0.12) 0%, rgba(255, 255, 255, 0) 55%);
  pointer-events: none;
}

.bubbleUser .text {
  position: relative;
  z-index: 1;
}

.bubbleUser .sources {
  position: relative;
  z-index: 1;
  border-color: rgba(255, 255, 255, 0.22);
  background: rgba(255, 255, 255, 0.14);
}

.bubbleUser .sourcesTitle {
  color: rgba(255, 255, 255, 0.9);
}

.bubbleUser .sourceItem {
  border-color: rgba(255, 255, 255, 0.16);
  background: rgba(255, 255, 255, 0.1);
}

.bubbleUser .sourceItem:hover {
  border-color: rgba(255, 255, 255, 0.28);
  background: rgba(255, 255, 255, 0.14);
}

.bubbleUser .sourceName {
  color: rgba(255, 255, 255, 0.96);
}

.msgActions {
  position: absolute;
  top: 8px;
  right: -38px;
  display: flex;
  align-items: center;
  gap: 6px;
  opacity: 0;
  pointer-events: none;
  transition: opacity 140ms ease;
  z-index: 2;
}

.rowUser .msgActions {
  left: -38px;
  right: auto;
}

.row:hover .msgActions,
.row:focus-within .msgActions {
  opacity: 1;
  pointer-events: auto;
}

.msgCopyBtn {
  width: 28px;
  height: 28px;
  border-radius: 10px;
  border: 1px solid transparent;
  background: rgba(255, 255, 255, 0.92);
  color: rgba(15, 23, 42, 0.7);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition:
    background 140ms ease,
    border-color 140ms ease,
    color 140ms ease,
    transform 140ms ease;
}

.msgCopyBtn:hover {
  border-color: rgba(47, 107, 255, 0.22);
  background: #fff;
  color: rgba(35, 89, 255, 0.95);
  transform: translateY(-1px);
}

.msgCopyBtn:disabled {
  opacity: 0.55;
  cursor: not-allowed;
}

.msgCopyIcon {
  width: 16px;
  height: 16px;
  font-size: 16px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.bubbleUser .msgCopyBtn {
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.9);
  border-color: rgba(255, 255, 255, 0.16);
}

.bubbleUser .msgCopyBtn:hover {
  background: rgba(255, 255, 255, 0.24);
  border-color: rgba(255, 255, 255, 0.26);
  color: #fff;
}

.bubbleStreaming {
  border-color: rgba(47, 107, 255, 0.2);
}

.bubbleError {
  border-color: rgba(185, 28, 28, 0.32);
  background: rgba(254, 242, 242, 0.9);
  color: #7f1d1d;
}

.rowAssistant .bubbleJoinedTop {
  border-top-left-radius: 10px;
}

.rowUser .bubbleJoinedTop {
  border-top-right-radius: 10px;
}

.rowAssistant .bubbleJoinedBottom {
  border-bottom-left-radius: 10px;
}

.rowUser .bubbleJoinedBottom {
  border-bottom-right-radius: 10px;
}

.text {
  white-space: normal;
  word-break: break-word;
  line-height: 1.55;
  font-size: 14px;
}

.rich {
  display: block;
}

.rich p {
  margin: 0;
}

.rich p + p {
  margin-top: 8px;
}

.rich h3,
.rich h4,
.rich h5 {
  margin: 0 0 6px;
  font-weight: 850;
  letter-spacing: -0.2px;
}

.rich h3 {
  font-size: 15px;
}

.rich h4 {
  font-size: 14px;
}

.rich h5 {
  font-size: 13px;
}

.rich ul,
.rich ol {
  margin: 6px 0 0;
  padding-left: 18px;
}

.rich li {
  margin: 2px 0;
}

.rich a {
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 2px;
}

.rich blockquote {
  margin: 10px 0 0;
  padding: 8px 12px;
  border-left: 3px solid rgba(2, 6, 23, 0.18);
  background: rgba(2, 6, 23, 0.04);
  border-radius: 12px;
}

.rich hr {
  margin: 10px 0 0;
  border: 0;
  border-top: 1px solid rgba(2, 6, 23, 0.12);
}

.rich img {
  max-width: 100%;
  height: auto;
  border-radius: 12px;
}

.rich table {
  width: 100%;
  border-collapse: collapse;
  margin: 10px 0 0;
  overflow: auto;
  display: block;
}

.rich th,
.rich td {
  border: 1px solid rgba(2, 6, 23, 0.12);
  padding: 6px 8px;
  text-align: left;
  vertical-align: top;
}

.rich th {
  font-weight: 800;
  background: rgba(2, 6, 23, 0.04);
}

.rich pre {
  margin: 10px 0 0;
  padding: 10px 12px;
  border-radius: 14px;
  border: 1px solid rgba(2, 6, 23, 0.08);
  background: rgba(2, 6, 23, 0.05);
  overflow: auto;
}

.rich pre code {
  display: block;
  font-family: var(--mono);
  font-size: 12px;
  line-height: 1.55;
  white-space: pre;
}

.rich code {
  font-family: var(--mono);
  font-size: 0.95em;
  padding: 1px 6px;
  border-radius: 8px;
  background: rgba(2, 6, 23, 0.06);
}

.rich pre code {
  padding: 0;
  background: transparent;
}

.bubbleUser .rich pre {
  border-color: rgba(255, 255, 255, 0.16);
  background: rgba(255, 255, 255, 0.12);
}

.bubbleUser .rich blockquote {
  border-left-color: rgba(255, 255, 255, 0.35);
  background: rgba(255, 255, 255, 0.12);
}

.bubbleUser .rich hr {
  border-top-color: rgba(255, 255, 255, 0.22);
}

.bubbleUser .rich th,
.bubbleUser .rich td {
  border-color: rgba(255, 255, 255, 0.22);
}

.bubbleUser .rich th {
  background: rgba(255, 255, 255, 0.1);
}

.bubbleUser .rich code {
  background: rgba(255, 255, 255, 0.16);
}

.sources {
  margin-top: 10px;
  padding: 10px;
  border-radius: 14px;
  border: 1px solid rgba(2, 6, 23, 0.08);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(247, 248, 250, 0.88) 100%);
}

.sourcesTitle {
  font-weight: 750;
  font-size: 12px;
  color: var(--text-h);
}

.sourcesList {
  margin-top: 8px;
  display: grid;
  gap: 8px;
  grid-template-columns: 1fr;
}

@media (min-width: 860px) {
  .sourcesList {
    grid-template-columns: 1fr 1fr;
  }
}

.sourceItem {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  border: 1px solid rgba(2, 6, 23, 0.08);
  border-radius: 12px;
  padding: 8px 10px;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: inset 3px 0 0 hsl(var(--source-h, 220) var(--source-s, 70%) var(--source-l, 45%) / 0.28);
  transition:
    background 140ms ease,
    border-color 140ms ease,
    box-shadow 140ms ease,
    transform 140ms ease;
}

.sourceItem::before {
  content: '';
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: hsl(var(--source-h, 220) var(--source-s, 70%) var(--source-l, 45%) / 0.55);
  box-shadow: inset hsl(var(--source-h, 220) var(--source-s, 70%) var(--source-l, 45%) / 0.62) 0 0 0 1px;
  flex: 0 0 auto;
}

.sourceItem:hover {
  background: #fff;
  border-color: hsl(var(--source-h, 220) var(--source-s, 70%) var(--source-l, 45%) / 0.22);
  box-shadow: inset 3px 0 0 hsl(var(--source-h, 220) var(--source-s, 70%) var(--source-l, 45%) / 0.42);
  transform: translateY(-1px);
}

.sourceName {
  min-width: 0;
  font-weight: 650;
  color: var(--text-h);
  font-size: 13px;
  line-height: 1.3;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-clamp: 2;
}

.sourceMeta {
  margin-top: 4px;
  font-size: 12px;
  color: var(--text);
  font-family: var(--mono);
}

.empty {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text);
  padding: 18px;
  text-align: center;
  background:
    radial-gradient(900px 500px at 50% 0%, rgba(47, 107, 255, 0.09) 0%, rgba(47, 107, 255, 0) 52%),
    transparent;
}

.emptyTitle {
  color: var(--text-h);
  font-weight: 800;
  font-size: 17px;
}

.emptyHint {
  margin-top: 8px;
  font-size: 13px;
}

.composerBar {
  position: sticky;
  bottom: 0;
  z-index: 2;
  background: #fff;
  border-top: 1px solid var(--border);
  padding: 10px 18px calc(10px + env(safe-area-inset-bottom, 0px));
  box-shadow: rgba(0, 0, 0, 0.06) 0 -8px 20px -16px;
}

.kbBar {
  margin-top: 10px;
  border: 1px solid var(--border);
  border-radius: 14px;
  background: #fff;
  padding: 8px 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  min-width: 0;
  flex-wrap: wrap;
}

.scopeLeft {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
  flex: 1 1 320px;
}

.scopeRight {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
  flex: 1 1 320px;
  justify-content: flex-end;
}

.kbLabel {
  font-size: 12px;
  color: var(--text);
  white-space: nowrap;
}

.scopeTabs {
  display: inline-flex;
  align-items: center;
  gap: 2px;
  padding: 2px;
  border: 1px solid #e9edf5;
  border-radius: 999px;
  background: #f7f8fa;
  flex-wrap: wrap;
}

.scopeBtn {
  height: 28px;
  padding: 0 10px;
  border-radius: 999px;
  border: 0;
  background: transparent;
  color: var(--text-h);
  cursor: pointer;
  font-weight: 700;
  font-size: 12px;
}

.scopeBtn:hover {
  background: rgba(2, 6, 23, 0.05);
}

.scopeBtnActive {
  background: #eef2ff;
  color: #2f6bff;
}

.scopeBtn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

.kbSelect {
  height: 32px;
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 0 10px;
  background: #fff;
  color: var(--text-h);
  min-width: 200px;
  outline: none;
  width: min(360px, 100%);
}

.kbSelect:focus {
  border-color: #2f6bff;
  box-shadow: 0 0 0 3px rgba(47, 107, 255, 0.15);
}

.kbSelect:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

@media (max-width: 860px) {
  .body {
    flex-direction: column;
  }

  .convPanel {
    flex: 0 0 auto;
    width: 100%;
    min-width: 0;
    max-width: none;
    max-height: 38vh;
    border-right: 0;
    border-bottom: 1px solid var(--border);
  }

  .convHeader {
    flex-wrap: wrap;
  }

  .thread {
    flex: 1;
  }

  .header {
    padding: 12px 12px 10px;
  }

  .title {
    font-size: 18px;
  }

  .messages {
    padding: 10px 12px 12px;
  }

  .composerBar {
    padding: 10px 12px calc(10px + env(safe-area-inset-bottom, 0px));
  }

  .kbBar {
    flex-direction: column;
    align-items: stretch;
  }

  .scopeLeft,
  .scopeRight {
    width: 100%;
    justify-content: space-between;
  }

  .scopeTabs {
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .kbSelect {
    width: 100%;
    min-width: 0;
  }
}
