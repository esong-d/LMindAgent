# ==========================================
# LMindAgent 配置模板
# 使用方式:
#   本地开发: cp .env.example .env 并填入真实值
#   Docker部署: cp .env.example .env.docker 并填入真实值
# ==========================================

# 运行环境 ["development", "test", "production"]
environment='development'

# 项目信息
project_name='LMindAgent'
project_version='0.1.0'
project_description='LMindAgent'
docs_url='/docs'
redoc_url='/redoc'
openapi_url='/openapi.json'

# 日志路径
log_path='./logs'

# API 前缀
api_prefix='/api'

# ── 数据库 ──────────────────────────────
# 本地开发: localhost
# Docker:    pgsql
database_url='postgresql+asyncpg://postgres:CHANGE_ME@pgsql:5432/local_mind_agent_db'

# 数据库连接池配置
echo=False
pool_recycle=1800
pool_size=20
max_overflow=10
pool_timeout=30
pool_pre_ping=True

# ── Redis ───────────────────────────────
# 本地开发: 127.0.0.1
# Docker:    redis
redis_url='redis://redis:6379/0'
cache_redis_url='redis://redis:6379/1'
queue_redis_url='redis://redis:6379/2'
pubsub_redis_url='redis://redis:6379/3'

# ── JWT ─────────────────────────────────
jwt_secret='CHANGE_ME'
jwt_expire=86400
jwt_algorithm='HS256'
refresh_token_expire=86400
access_token_expire=900

# ── 加密 ────────────────────────────────
encryption_key='CHANGE_ME'
encryption_key_description='用于文件加密'
aes_key_hex='CHANGE_ME'

# ── 文件存储 ────────────────────────────
storage_backend='local'
storage_local_dir='./uploads'
max_upload_mb=200
allowed_upload_mime_types=["text/plain", "text/markdown", "application/pdf", "application/vnd.openxmlformats-officedocument.wordprocessingml.document"]

# ── CORS ────────────────────────────────
public_base_url=""

# ── LLM / OpenAI ────────────────────────
llm_default_base_url='https://api.openai.com/v1'
llm_request_timeout_seconds=60.0

# 嵌入模型
embedding_vector_model="text-embedding-3-small"
embedding_vector_dim=1536

# OpenAI API（嵌入模型需要）或者中转站（支持openai 嵌入模型）
openai_api_base="https://api.openai.com/v1"
openai_api_key="sk-CHANGE_ME"

# ── 检索配置 ────────────────────────────
retrieval_default_top_k=50

# 重排配置
RERANKER_MODEL_NAME="BAAI/bge-base-en-v1.5"
RERANKER_USE_FP16=True
RERANKER_TOP_K=5

# ── LangSmith 可观测性（可选）─────────────
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=""
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT=""

# ── 文档处理 ─────────────────────────────
max_retry_times=3
